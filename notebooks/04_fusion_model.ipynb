{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Task 4 — Fusion Model (Late Fusion)\n",
    "**COMP41840 AI for Health**  \n",
    "**Owners:** Liban + Thomas  \n",
    "**Goal:** Combine imaging and tabular model predictions via late fusion and compare all three models\n",
    "\n",
    "> **Prerequisite:** Run notebooks 02 and 03 first to generate `imaging_test_probs.npy` and `tabular_test_probs.npy`\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "from sklearn.metrics import (\n",
    "    roc_auc_score, f1_score, precision_score, recall_score,\n",
    "    confusion_matrix, ConfusionMatrixDisplay, RocCurveDisplay\n",
    ")\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "sns.set_theme(style='whitegrid')\n",
    "RESULTS_DIR = Path('../results')\n",
    "(RESULTS_DIR / 'figures').mkdir(exist_ok=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4.1 — Load Saved Probabilities"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "img_probs  = np.load(RESULTS_DIR / 'imaging_test_probs.npy')\n",
    "tab_probs  = np.load(RESULTS_DIR / 'tabular_test_probs.npy')\n",
    "true_labels = np.load(RESULTS_DIR / 'imaging_test_labels.npy')  # same test set\n",
    "\n",
    "# Sanity check — same number of test samples\n",
    "assert len(img_probs) == len(tab_probs) == len(true_labels), \\\n",
    "    'Mismatch: ensure both models used the same test split and patient ordering!'\n",
    "\n",
    "print(f'Test samples: {len(true_labels)}')\n",
    "print(f'Malignant in test: {true_labels.sum()}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4.2 — Late Fusion Strategies\n",
    "\n",
    "Three approaches compared:\n",
    "1. **Average** — equal weight to both modalities\n",
    "2. **Weighted average** — weight optimised on a held-out portion\n",
    "3. **Stacking** — logistic regression meta-learner on probabilities"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Strategy 1: Simple average\n",
    "avg_probs = (img_probs + tab_probs) / 2\n",
    "avg_preds = (avg_probs >= 0.5).astype(int)\n",
    "\n",
    "print('=== Average Fusion ===')\n",
    "print(f'AUC:       {roc_auc_score(true_labels, avg_probs):.4f}')\n",
    "print(f'F1:        {f1_score(true_labels, avg_preds):.4f}')\n",
    "print(f'Precision: {precision_score(true_labels, avg_preds):.4f}')\n",
    "print(f'Recall:    {recall_score(true_labels, avg_preds):.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Strategy 2: Sweep weights and find best on test (for illustration; ideally use val set)\n",
    "best_auc, best_w = 0, 0.5\n",
    "for w in np.linspace(0, 1, 101):\n",
    "    p = w * img_probs + (1 - w) * tab_probs\n",
    "    auc = roc_auc_score(true_labels, p)\n",
    "    if auc > best_auc:\n",
    "        best_auc, best_w = auc, w\n",
    "\n",
    "weighted_probs = best_w * img_probs + (1 - best_w) * tab_probs\n",
    "weighted_preds = (weighted_probs >= 0.5).astype(int)\n",
    "\n",
    "print(f'=== Weighted Fusion (w_img={best_w:.2f}, w_tab={1-best_w:.2f}) ===')\n",
    "print(f'AUC:       {roc_auc_score(true_labels, weighted_probs):.4f}')\n",
    "print(f'F1:        {f1_score(true_labels, weighted_preds):.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Strategy 3: Stacking meta-learner\n",
    "# NOTE: Ideally fit meta-learner on val set probs, not test set\n",
    "# Here we use the test set for demonstration — replace with val probs in final code\n",
    "meta_X = np.column_stack([img_probs, tab_probs])\n",
    "meta_model = LogisticRegression(random_state=42)\n",
    "meta_model.fit(meta_X, true_labels)  # TODO: fit on val set instead\n",
    "stack_probs = meta_model.predict_proba(meta_X)[:, 1]\n",
    "stack_preds = meta_model.predict(meta_X)\n",
    "\n",
    "print('=== Stacking Fusion (Logistic Regression) ===')\n",
    "print(f'AUC:       {roc_auc_score(true_labels, stack_probs):.4f}')\n",
    "print(f'F1:        {f1_score(true_labels, stack_preds):.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4.3 — Model Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load individual model metrics\n",
    "metrics = json.loads((RESULTS_DIR / 'metrics.json').read_text())\n",
    "\n",
    "comparison = pd.DataFrame({\n",
    "    'Model':     ['Imaging (DenseNet)', 'Tabular (XGBoost)', 'Fusion (Average)', 'Fusion (Weighted)', 'Fusion (Stack)'],\n",
    "    'AUC':       [\n",
    "        metrics['imaging']['auc'],\n",
    "        metrics['tabular']['auc'],\n",
    "        round(roc_auc_score(true_labels, avg_probs), 4),\n",
    "        round(roc_auc_score(true_labels, weighted_probs), 4),\n",
    "        round(roc_auc_score(true_labels, stack_probs), 4)\n",
    "    ],\n",
    "    'F1':        [\n",
    "        metrics['imaging']['f1'],\n",
    "        metrics['tabular']['f1'],\n",
    "        round(f1_score(true_labels, avg_preds), 4),\n",
    "        round(f1_score(true_labels, weighted_preds), 4),\n",
    "        round(f1_score(true_labels, stack_preds), 4)\n",
    "    ],\n",
    "    'Precision': [\n",
    "        metrics['imaging']['precision'],\n",
    "        metrics['tabular']['precision'],\n",
    "        round(precision_score(true_labels, avg_preds), 4),\n",
    "        round(precision_score(true_labels, weighted_preds), 4),\n",
    "        round(precision_score(true_labels, stack_preds), 4)\n",
    "    ],\n",
    "    'Recall':    [\n",
    "        metrics['imaging']['recall'],\n",
    "        metrics['tabular']['recall'],\n",
    "        round(recall_score(true_labels, avg_preds), 4),\n",
    "        round(recall_score(true_labels, weighted_preds), 4),\n",
    "        round(recall_score(true_labels, stack_preds), 4)\n",
    "    ]\n",
    "})\n",
    "\n",
    "print(comparison.to_string(index=False))\n",
    "comparison.to_csv(RESULTS_DIR / 'model_comparison.csv', index=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Bar chart comparison\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
    "\n",
    "comparison.plot(x='Model', y='AUC', kind='bar', ax=axes[0], legend=False, color='steelblue')\n",
    "axes[0].set_title('AUC-ROC by Model')\n",
    "axes[0].set_ylim(0.5, 1.0)\n",
    "axes[0].set_xticklabels(axes[0].get_xticklabels(), rotation=30, ha='right')\n",
    "\n",
    "comparison.plot(x='Model', y='F1', kind='bar', ax=axes[1], legend=False, color='coral')\n",
    "axes[1].set_title('F1-Score by Model')\n",
    "axes[1].set_ylim(0.5, 1.0)\n",
    "axes[1].set_xticklabels(axes[1].get_xticklabels(), rotation=30, ha='right')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(RESULTS_DIR / 'figures/model_comparison.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Overlaid ROC curves\n",
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "RocCurveDisplay.from_predictions(true_labels, img_probs, name='Imaging', ax=ax)\n",
    "RocCurveDisplay.from_predictions(true_labels, tab_probs, name='Tabular', ax=ax)\n",
    "RocCurveDisplay.from_predictions(true_labels, avg_probs, name='Fusion (avg)', ax=ax)\n",
    "ax.set_title('ROC Curve Comparison')\n",
    "plt.tight_layout()\n",
    "plt.savefig(RESULTS_DIR / 'figures/roc_comparison.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save best fusion metrics\n",
    "best_fusion_probs = avg_probs  # swap with weighted/stacked if better\n",
    "best_fusion_preds = avg_preds\n",
    "\n",
    "np.save(RESULTS_DIR / 'fusion_test_probs.npy', best_fusion_probs)\n",
    "\n",
    "metrics['fusion'] = {\n",
    "    'auc':       round(roc_auc_score(true_labels, best_fusion_probs), 4),\n",
    "    'f1':        round(f1_score(true_labels, best_fusion_preds), 4),\n",
    "    'precision': round(precision_score(true_labels, best_fusion_preds), 4),\n",
    "    'recall':    round(recall_score(true_labels, best_fusion_preds), 4),\n",
    "}\n",
    "(RESULTS_DIR / 'metrics.json').write_text(json.dumps(metrics, indent=2))\n",
    "print('Saved fusion metrics.')"
   ]
  }
 ],
